generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
 
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  files File[]
}

model File {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  path      String
  createdAt DateTime @default(now())

  authorId  Int
  author    User @relation(fields: [authorId], references: [id])
}
