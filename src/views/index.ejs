<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homepage</title>
</head>
<body>
    <div class="container">
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <% if(user) { %>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/logout">Logout</a></li>
                    <li><a href="/dashboard">Dashboard</a></li>

                <% } %>
                <% if(!user) { %>
                  <li><a href="/login">Login</a></li>
                <li><a href="/signup">Sign Up</a></li>
               <% } %>
              
            </ul>
        </nav>
        <h1>Welcome to File Uploader<% if(user) {%>, <%=user.username%><%}%>
        </h1>
        <div class="subcontainer">
            <div class="intro">
                <p>Welcome to the File Uploader! Upload your files with ease...
                </p>
            </div>
            <div class="image">
                <img src="../images/2765820.jpg" alt="upload image" width="400px" height="300px">
            </div>
        </div>

        <% if (user) { %>
            <button><a href="/createFolder">Create Folder</a></button>
            <br><br>
                <button><a href="/upload">Upload File</a></button>
          
        <%} %>
    </div>
</body>
</html>