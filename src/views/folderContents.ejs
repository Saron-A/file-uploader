<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Folder Contents</h1>
    <ul>
        <% if (files.length > 0) { %>
 <% files.forEach((file) => {%>
            <a href="/files/<%= file.id %>" target="_blank">
                <li>
                    <img src="" alt="file icon">
                    <p><%= file.name %></p>
                </li>
            </a>

       <% }) } else { %>
            <p>No files in this folder.</p>
       <% } %>
       
    
       
    </ul>
</body>
</html>