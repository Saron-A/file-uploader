<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Folder Contents</h1>
    <ul>
        <% files.forEach((file) => {%>
            <a href="/<%= file.path %>" target="_blank">
                <li>
                    <img src="" alt="file icon">
                    <p><%= file.name %></p>
                </li>
            </a>

        })
    </ul>
</body>
</html>